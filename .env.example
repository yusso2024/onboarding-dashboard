# ============================================
# Onboarding Dashboard — Environment Config
# ============================================

# --- Auth Service DB (PostgreSQL) ---
AUTH_DB_HOST=auth-db
AUTH_DB_PORT=5432
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=CHANGE_ME
AUTH_DB_NAME=auth_db

# --- User Service DB (PostgreSQL) ---
USER_DB_HOST=user-db
USER_DB_PORT=5432
USER_DB_USER=user_user
USER_DB_PASSWORD=CHANGE_ME
USER_DB_NAME=user_db

# --- Inventory Service DB (MongoDB) ---
INVENTORY_DB_HOST=inventory-db
INVENTORY_DB_PORT=27017
INVENTORY_DB_USER=inventory_user
INVENTORY_DB_PASSWORD=CHANGE_ME
INVENTORY_DB_NAME=inventory_db

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ---
JWT_SECRET=CHANGE_ME

# --- Service Ports (internal) ---
AUTH_PORT=3000
USER_PORT=3000
INVENTORY_PORT=3000

# --- Jaeger (Distributed Tracing) ---
JAEGER_ENDPOINT=jaeger:4318
